rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function hasRole(role) {
      return isAuthenticated() &&
             request.auth.token.role == role;
    }

    function isAdmin() {
      return hasRole('admin');
    }

    function isAgent() {
      return hasRole('agent');
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // USERS
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if false; // Cloud Functions only

      // Update: Owner can update own profile except role/isActive
      // Admin can update everything (including role/isActive)
      allow update: if (isOwner(userId) &&
                        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'isActive']))
                    || isAdmin();

      allow delete: if false;
    }

    // TERRAINS
    match /terrains/{terrainId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // RESERVATIONS
    match /reservations/{resId} {
      allow read: if isAuthenticated() &&
                 (resource.data.userId == request.auth.uid || isAdmin());

      // Create: Owner for self OR Admin for anyone
      // Conflict detection: Enforced by Cloud Function triggers (async) or transaction logic in client SDK
      // Rules cannot easily scan collection for time overlaps efficiently.
      allow create: if isAuthenticated() &&
                       (request.resource.data.userId == request.auth.uid || isAdmin());

      // Update: Owner can only CANCEL
      // Admin can update any field (reschedule, confirm, etc.)
      allow update: if (isOwner(resource.data.userId) &&
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt']) &&
                        request.resource.data.status == 'cancelled')
                    || isAdmin();

      allow delete: if isAdmin();
    }

    // STOCK - Sensitive info (prices, inventory levels)
    match /stock/{itemId} {
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // MAINTENANCES
    match /maintenances/{maintenanceId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // AUDIT LOGS - Immutable, System/Admin only
    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow write: if false; // Cloud Functions via Admin SDK only
    }
  }
}
