rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function hasRole(role) {
      return isAuthenticated() &&
             request.auth.token.role == role;
    }

    function isAdmin() {
      return hasRole('admin');
    }

    function isAgent() {
      return hasRole('agent');
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // USERS
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if false; // Cloud Functions only

      // Update: Owner can update own profile except role/isActive
      // Admin can update everything (including role/isActive)
      allow update: if (isOwner(userId) &&
                        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'isActive']))
                    || isAdmin();

      allow delete: if false;
    }

    // TERRAINS
    match /terrains/{terrainId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // RESERVATIONS
    match /reservations/{resId} {
      // Read: Owner, Admin, or same terrain (for availability check - simplified here)
      allow read: if isOwner(resource.data.userId) || isAdmin();

      // Create: Self or Admin (Cloud Function handles conflict detection)
      allow create: if (request.auth.uid == request.resource.data.userId || isAdmin())
                    && request.resource.data.status == 'pending'
                    && request.resource.data.startTime < request.resource.data.endTime
                    && request.resource.data.startTime > request.time
                    && request.resource.data.terrainId != null;

      // Update: Owner can cancel, Admin can do anything
      allow update: if (isOwner(resource.data.userId) && request.resource.data.status == 'cancelled')
                    || isAdmin();

      // Delete: Admin only
      allow delete: if isAdmin();
    }

    // STOCK - Sensitive info (prices, inventory levels)
    match /stock/{itemId} {
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // MAINTENANCES
    match /maintenances/{maintenanceId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // AUDIT LOGS - Immutable, System/Admin only
    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow write: if false; // Cloud Functions via Admin SDK only
    }
  }
}
