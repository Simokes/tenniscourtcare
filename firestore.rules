rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'admin';
    }

    function isMember() {
      return isAuthenticated() && (getUserRole() == 'admin' || getUserRole() == 'agent' || getUserRole() == 'secretary');
    }

    // Terrains: admin write, membres read
    match /terrains/{terrainId} {
      allow read: if isMember();
      allow write: if isAdmin();
    }

    // Maintenances: admin write, agent write, membres read
    match /maintenance/{maintenanceId} {
      allow read: if isMember();
      allow create, update: if isAuthenticated() && (getUserRole() == 'admin' || getUserRole() == 'agent');
      allow delete: if isAdmin();
    }

    // Stocks: admin write, membres read
    match /stocks/{stockId} {
      allow read: if isMember();
      allow write: if isAdmin();
    }

    // Events (calendrier): admin write, membres read
    match /events/{eventId} {
      allow read: if isMember();
      allow write: if isAdmin();
    }

    // Users: admin read/write, membre lit uniquement son propre doc
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }

    // ClubInfo: admin write, membres read
    match /clubInfo/{docId} {
      allow read: if isMember();
      allow write: if isAdmin();
    }

    // Par defaut: aucun acces
    match /{document=**} {
      allow read, write: if false;
    }
  }
}